# Копіюйте в `.env` локально. Префікс VITE_ обов’язковий для клієнта.

# Сума резерву за бронь (грн) — «фіксована ціна на момент бронювання»
VITE_RESERVATION_FEE_UAH=200

# Орієнтовна потужність зарядки для розрахунку енергії за час броні (кВт)
VITE_ASSUMED_CHARGE_KW=7

# Курс EUR→UAH (тарифи станцій у кабінеті користувача зберігаються в EUR/кВт·год)
VITE_EUR_TO_UAH=45
